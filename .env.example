# Required for the portfolio /api/second-brain-chat proxy.
# Must match BACKEND_API_SECRET configured in second-brain/sb-backend.
SECOND_BRAIN_BACKEND_SECRET=

# Optional. Defaults to this URL when omitted.
SECOND_BRAIN_API_URL=https://rag.haseebzaheer.dev/api/chat

# Optional proxy controls. Defaults shown here match the Vercel function.
SECOND_BRAIN_RATE_LIMIT_PER_MINUTE=5
SECOND_BRAIN_RATE_LIMIT_PER_DAY=25
SECOND_BRAIN_REQUEST_TIMEOUT_MS=55000
